<form action=reg>
 <div class="card">
     <h2> Registeration Form</h2>
     <h3>Register Here</h3>
     <p>Enter Your Details Below</p>
     <p>Note:- You Cannot Enter Same Id Twice or Else The Next Page Will Appear Blank.</p>
      <label for="id"><b>Id</b></label><br/>
      <input type="text" placeholder="Enter Id(eg:A101)" name="id" required><br/>

      <label for="fname"><b>First Name</b></label><br/>
      <input type="text" placeholder="Enter First Name" name="fname" required><br/>

      <label for="lname"><b>Last Name</b></label><br/>
      <input type="text" placeholder="Enter Last Name" name="lname" required><br/>
       
      <label for="uname"><b>Username</b></label><br/>
      <input type="text" placeholder="Enter Username" name="uname" required><br/>

      <label for="pword"><b>Password</b></label><br/>
      <input type="password" placeholder="Enter Password" name="pword" required><br/>

      <label for="email"><b>Email</b></label><br/>
      <input type="text" placeholder="Enter Email" name="email" required><br/>

      <input type="submit" class="btn">
          <input type="reset"  class="btn"><br/>
